{
  "name": "okcli",
  "version": "0.1.0",
  "description": "A Claude-powered CLI agent",
  "main": "dist/index.js",
  "bin": {
    "okcli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "cd web && npm run build",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "server": "ts-node src/server.ts",
    "dev:server": "ts-node src/server.ts",
    "dev:web": "cd web && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
